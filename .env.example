# Google Ads MCP – environment configuration
# Copy to .env and fill in your values:  cp .env.example .env
# .env is gitignored. The target customer_id is NOT set here – it is passed
# per request by the agent.

# ============================================================================
# LOCAL (stdio) – the default. Authenticates with YOUR Google Ads credentials.
# This is what you use with local tools like Claude Desktop
# ============================================================================

# Your Google Ads API developer token.
# https://developers.google.com/google-ads/api/docs/get-started/dev-token
GOOGLE_ADS_DEVELOPER_TOKEN=

# OAuth2 client (Desktop or Web type) created in your Google Cloud project.
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# OAuth2 refresh token. Generate once:  uv run auth/generate_refresh_token.py -c client_secret.json
# (see auth/README.md). Sign in with a Google account that can access the accounts you want.
GOOGLE_ADS_REFRESH_TOKEN=

# Optional. Set ONLY if you operate through a manager (MCC) account; digits, no dashes.
# Leave empty for directly-shared accounts.
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Optional alternative to the four vars above: point at a google-ads.yaml file
# and the SDK loads everything from it.
# GOOGLE_ADS_CONFIGURATION_FILE_PATH=/abs/path/to/google-ads.yaml

# Optional. DEBUG | INFO | WARNING | ERROR (default INFO).
# LOG_LEVEL=INFO


# ============================================================================
# REMOTE (HTTP) – multi-tenant. Each user signs in with THEIR OWN Google
# account and only sees accounts they can access. The server is a pure OAuth
# Resource Server: it verifies each request's Google token and forwards it to
# the Ads API. It runs no OAuth flow and holds NO client secret. Uncomment for
# a hosted deployment (see docs/REMOTE_DEPLOY.md). Do NOT set the LOCAL
# refresh-token vars above in this mode – the server holds only the developer
# token.
# ============================================================================

# The HTTP transport is always authenticated with per-user Google OAuth.
# MCP_TRANSPORT=http
# HOST=0.0.0.0
# PORT=8080
# MCP_HTTP_PATH=/

# Google OAuth 2.0 Web client ID. Used only to check each token's `aud` claim.
# The client SECRET does NOT live here – the MCP client (e.g. Claude) holds it
# and runs the OAuth flow directly against Google. Register the client's
# callbacks (e.g. https://claude.ai/api/mcp/auth_callback) as the OAuth client's
# redirect URIs – NOT a URL on this server.
# GOOGLE_OAUTH_CLIENT_ID=000000000000-xxxxxxxx.apps.googleusercontent.com

# Public base URL of this server, advertised in
# /.well-known/oauth-protected-resource. Must match what clients connect to.
# RESOURCE_SERVER_URL=https://your-service.example.com

# Still required (operator's app-level token; shared across users).
# GOOGLE_ADS_DEVELOPER_TOKEN=
